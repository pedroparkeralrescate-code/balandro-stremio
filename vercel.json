{
    "version": 2,
    "builds": [
        {
            "src": "api/**/*.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/manifest.json",
            "dest": "/api/manifest.py"
        },
        {
            "src": "/catalog/(.*)",
            "dest": "/api/catalog.py"
        },
        {
            "src": "/stream/(.*)",
            "dest": "/api/streams.py"
        },
        {
            "src": "/meta/(.*)",
            "dest": "/api/meta.py"
        }
    ]
}